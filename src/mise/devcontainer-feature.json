{
  "name": "mise-en-place",
  "id": "mise",
  "version": "1.3.0",
  "description": "Installs the mise CLI",
  "documentationURL": "https://github.com/kuboon/devcontainer-features/tree/main/src/mise",
  "licenseURL": "https://raw.githubusercontent.com/jdx/mise/refs/heads/main/LICENSE",
  "options": {
    "global": {
      "type": "string",
      "default": "lazygit@latest",
      "description": "`mise use -g [args]` to install global tools. For example, `deno ruby lazygit lazydocker cargo:cargo-binstall`."
    },
    "activate": {
      "type": "string",
      "proposals": ["none", "path", "shims"],
      "default": "shims",
      "description": "Select how to activate mise in the system. `none` means no activation, `path` means add to PATH, and `shims` means use shims to activate. Supports bash and zsh."
    },
  },
  "customizations": {
    "jetbrains": {
      "plugins": [
        "com.github.l34130.mise"
      ]
    },
    "vscode": {
      "extensions": [
        "hverlin.mise-vscode"
      ]
    }
  },
  "postCreateCommand": "/usr/local/share/mise-feature/post-create.sh",
  "installsAfter": ["ghcr.io/devcontainers/features/common-utils"]
}