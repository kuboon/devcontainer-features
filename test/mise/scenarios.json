{
  "default": {
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "features": {
      "mise": {}
    }
  },
  "activate-none": {
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "features": {
      "mise": {
        "activate": "none"
      }
    }
  },
  "activate-path": {
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "features": {
      "mise": {
        "activate": "path"
      }
    }
  },
  "activate-shims": {
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "features": {
      "mise": {
        "activate": "shims"
      }
    }
  },
  "specify-user": {
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "features": {
      "ghcr.io/devcontainers/features/common-utils:2": {
        "username": "mise"
      },
      "mise": {}
    },
    "remoteUser": "mise"
  },
  "activate-zsh": {
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "features": {
      "ghcr.io/devcontainers/features/common-utils:2": {
        "installZsh": true
      },
      "mise": {}
    }
  },
  "trust-true": {
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "features": {
      "mise": { }
    },
    "updateContentCommand": "touch mise.toml"
  },
  "trust-env": {
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "features": {
      "mise": { }
    },
    "containerEnv": {
      "MISE_TRUSTED_CONFIG_PATHS": "${containerWorkspaceFolder}"
    },
    "updateContentCommand": "touch mise.toml && mkdir child && touch child/mise.toml"
  },
  "install-true": {
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "features": {
      "mise": { }
    },
    "updateContentCommand": "echo 'tools.bat = \"latest\"' > mise.toml"
  },
  "global-opt": {
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "features": {
      "mise": {
        "global": "deno"
      }
    }
  }
}
